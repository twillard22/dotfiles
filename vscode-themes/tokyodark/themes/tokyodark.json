{
  "name": "Tokyo Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#11121D",
    "editor.foreground": "#A0A8CD",
    "editor.lineHighlightBackground": "#1A1B2A",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#212234",
    "editor.selectionHighlightBackground": "#353945",
    "editor.wordHighlightBackground": "#353945",
    "editor.wordHighlightStrongBackground": "#353945",
    "editor.findMatchBackground": "#06080A98",
    "editor.findMatchHighlightBackground": "#98C37940",
    "editor.rangeHighlightBackground": "#1A1B2A",
    "editorCursor.foreground": "#A0A8CD",
    "editorCursor.background": "#11121D",
    "editorWhitespace.foreground": "#4A5057",
    "editorIndentGuide.background": "#212234",
    "editorIndentGuide.activeBackground": "#353945",
    "editorRuler.foreground": "#212234",
