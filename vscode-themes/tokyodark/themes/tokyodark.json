    "editorLineNumber.foreground": "#4A5057",
    "editorLineNumber.activeForeground": "#A0A8CD",

    "editorError.foreground": "#EE6D85",
    "editorWarning.foreground": "#D7A65F",
    "editorInfo.foreground": "#7199EE",
    "editorHint.foreground": "#A485DD",
    "editorError.background": "#EE6D8518",
    "editorWarning.background": "#D7A65F18",

    "diffEditor.insertedTextBackground": "#1E232640",
    "diffEditor.removedTextBackground": "#281B2740",
    "diffEditor.insertedLineBackground": "#1E2326",
    "diffEditor.removedLineBackground": "#281B27",
    "editorGutter.addedBackground": "#587738",
    "editorGutter.modifiedBackground": "#2A3A5A",
    "editorGutter.deletedBackground": "#773440",
    "gitDecoration.addedResourceForeground": "#95C561",
    "gitDecoration.modifiedResourceForeground": "#7199EE",
    "gitDecoration.deletedResourceForeground": "#EE6D85",
    "gitDecoration.untrackedResourceForeground": "#95C561",
    "gitDecoration.ignoredResourceForeground": "#4A5057",
    "gitDecoration.conflictingResourceForeground": "#D7A65F",

    "activityBar.background": "#1A1B2A",
    "activityBar.foreground": "#A0A8CD",
    "activityBar.inactiveForeground": "#4A5057",
    "activityBar.border": "#282C34",
    "activityBarBadge.background": "#7199EE",
    "activityBarBadge.foreground": "#11121D",

    "sideBar.background": "#11121D",
    "sideBar.foreground": "#A0A8CD",
    "sideBar.border": "#282C34",
    "sideBarTitle.foreground": "#A0A8CD",
    "sideBarSectionHeader.background": "#1A1B2A",
    "sideBarSectionHeader.foreground": "#A0A8CD",

    "editorGroupHeader.tabsBackground": "#1A1B2A",
    "tab.activeBackground": "#11121D",
    "tab.activeForeground": "#A0A8CD",
    "tab.activeBorderTop": "#FE6D85",
    "tab.inactiveBackground": "#1A1B2A",
    "tab.inactiveForeground": "#4A5057",
    "tab.border": "#282C34",
    "tab.unfocusedActiveBackground": "#11121D",
    "tab.unfocusedActiveForeground": "#A0A8CD80",

    "statusBar.background": "#212234",
    "statusBar.foreground": "#A0A8CD",
    "statusBar.border": "#282C34",
    "statusBar.noFolderBackground": "#212234",
    "statusBar.debuggingBackground": "#EE6D85",
    "statusBar.debuggingForeground": "#11121D",
    "statusBarItem.remoteBackground": "#7199EE",
    "statusBarItem.remoteForeground": "#11121D",

    "titleBar.activeBackground": "#1A1B2A",
    "titleBar.activeForeground": "#A0A8CD",
    "titleBar.inactiveBackground": "#11121D",
    "titleBar.inactiveForeground": "#4A5057",
    "titleBar.border": "#282C34",

    "panel.background": "#11121D",
    "panel.border": "#282C34",
    "panelTitle.activeForeground": "#A0A8CD",
    "panelTitle.activeBorder": "#FE6D85",
    "panelTitle.inactiveForeground": "#4A5057",

    "terminal.background": "#11121D",
    "terminal.foreground": "#A0A8CD",
    "terminal.ansiBlack": "#06080A",
    "terminal.ansiBrightBlack": "#212234",
    "terminal.ansiRed": "#EE6D85",
    "terminal.ansiBrightRed": "#EE6D85",
    "terminal.ansiGreen": "#95C561",
    "terminal.ansiBrightGreen": "#95C561",
    "terminal.ansiYellow": "#D7A65F",
    "terminal.ansiBrightYellow": "#D7A65F",
    "terminal.ansiBlue": "#7199EE",
    "terminal.ansiBrightBlue": "#7199EE",
    "terminal.ansiMagenta": "#A485DD",
    "terminal.ansiBrightMagenta": "#A485DD",
    "terminal.ansiCyan": "#38A89D",
    "terminal.ansiBrightCyan": "#38A89D",
    "terminal.ansiWhite": "#A0A8CD",
    "terminal.ansiBrightWhite": "#A0A8CD",

    "editorWidget.background": "#11121D",
    "editorWidget.border": "#4A5057",
    "editorSuggestWidget.background": "#11121D",
    "editorSuggestWidget.foreground": "#A0A8CD",
    "editorSuggestWidget.selectedBackground": "#212234",
    "editorSuggestWidget.highlightForeground": "#7199EE",
    "editorSuggestWidget.border": "#4A5057",
    "editorHoverWidget.background": "#11121D",
    "editorHoverWidget.border": "#4A5057",

    "input.background": "#1A1B2A",
    "input.foreground": "#A0A8CD",
    "input.border": "#4A5057",
    "input.placeholderForeground": "#4A5057",
    "inputOption.activeBorder": "#7199EE",
    "dropdown.background": "#11121D",
    "dropdown.foreground": "#A0A8CD",
    "dropdown.border": "#4A5057",

    "list.activeSelectionBackground": "#212234",
    "list.activeSelectionForeground": "#A0A8CD",
    "list.hoverBackground": "#1A1B2A",
    "list.hoverForeground": "#A0A8CD",
    "list.inactiveSelectionBackground": "#1A1B2A",
    "list.inactiveSelectionForeground": "#A0A8CD",
    "list.focusBackground": "#212234",
    "list.focusForeground": "#A0A8CD",
    "list.highlightForeground": "#7199EE",
    "listFilterWidget.background": "#11121D",
    "listFilterWidget.outline": "#7199EE",

    "scrollbarSlider.background": "#35394580",
    "scrollbarSlider.hoverBackground": "#4A505780",
    "scrollbarSlider.activeBackground": "#4A5057",

    "button.background": "#7199EE",
    "button.foreground": "#11121D",
    "button.hoverBackground": "#9FBBF3",
    "badge.background": "#7199EE",
    "badge.foreground": "#11121D",
    "progressBar.background": "#7199EE",

    "focusBorder": "#7199EE80",
    "contrastBorder": "#00000000",
    "widget.shadow": "#06080A80",

    "notifications.background": "#11121D",
    "notifications.foreground": "#A0A8CD",
    "notifications.border": "#4A5057",
    "notificationCenterHeader.background": "#1A1B2A",
    "notificationCenterHeader.foreground": "#A0A8CD",
    "notificationLink.foreground": "#7199EE",

    "peekView.border": "#7199EE",
    "peekViewEditor.background": "#11121D",
    "peekViewEditor.matchHighlightBackground": "#1C447460",
    "peekViewResult.background": "#1A1B2A",
    "peekViewResult.fileForeground": "#A0A8CD",
    "peekViewResult.lineForeground": "#4A5057",
    "peekViewResult.matchHighlightBackground": "#1C447460",
    "peekViewResult.selectionBackground": "#212234",
    "peekViewResult.selectionForeground": "#A0A8CD",
    "peekViewTitle.background": "#1A1B2A",
    "peekViewTitleLabel.foreground": "#A0A8CD",
    "peekViewTitleDescription.foreground": "#4A5057"
  },
  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.return",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#EE6D85" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator"
      ],
      "settings": { "foreground": "#EE6D85" }
    },
    {
      "name": "Preprocessor / include",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.other.import"
      ],
      "settings": { "foreground": "#EE6D85" }
    },
    {
      "name": "Functions (definitions)",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#95C561" }
    },
    {
      "name": "Methods",
      "scope": [
        "entity.name.function.method",
        "meta.function-call.method",
        "variable.function"
      ],
      "settings": { "foreground": "#95C561" }
    },
    {
      "name": "Types / classes / interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.struct",
        "entity.name.enum",
        "support.type",
        "support.class",
        "storage.type.class",
        "storage.type.interface"
      ],
      "settings": { "foreground": "#7199EE" }
    },
    {
      "name": "Namespaces / modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.other.namespace"
      ],
      "settings": { "foreground": "#EE6D85" }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#A0A8CD" }
    },
    {
      "name": "Parameters / identifiers",
      "scope": [
        "variable.parameter",
        "entity.name.variable",
        "meta.parameter"
      ],
      "settings": { "foreground": "#F6955B" }
    },
    {
      "name": "Properties / fields",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.member"
      ],
      "settings": { "foreground": "#F6955B" }
    },
    {
      "name": "Constants",
      "scope": [
        "variable.other.constant",
        "constant.other",
        "entity.name.constant"
      ],
      "settings": { "foreground": "#F6955B" }
    },
    {
      "name": "Built-in variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.template"
      ],
      "settings": { "foreground": "#D7A65F" }
    },
    {
      "name": "String escapes / special",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Characters",
      "scope": [
        "constant.character"
      ],
      "settings": { "foreground": "#D7A65F" }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Floats",
      "scope": [
        "constant.numeric.float",
        "constant.numeric.decimal"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.language.true",
        "constant.language.false"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Null / undefined",
      "scope": [
        "constant.language",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nil"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": { "foreground": "#4A5057" }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": { "foreground": "#4A5057" }
    },
    {
      "name": "TODO / NOTE in comments",
      "scope": [
        "keyword.codetag.notation",
        "comment.todo",
        "comment.notice",
        "storage.type.class.todo"
      ],
      "settings": { "foreground": "#7199EE" }
    },
    {
      "name": "Macros",
      "scope": [
        "entity.name.function.preprocessor",
        "keyword.other.macro",
        "meta.macro"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Labels",
      "scope": [
        "entity.name.label"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Tags (HTML/JSX element names)",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": { "foreground": "#F6955B" }
    },
    {
      "name": "Tag attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": { "foreground": "#F6955B" }
    },
    {
      "name": "Punctuation / delimiters",
      "scope": [
        "punctuation.definition",
        "punctuation.terminator",
        "punctuation.section",
        "meta.brace",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": { "foreground": "#A0A8CD" }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": { "foreground": "#D7A65F" }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "meta.annotation"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Heading (markdown)",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "markup.heading.markdown punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#D7A65F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bold (markdown)",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#A0A8CD",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic (markdown)",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#A0A8CD",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Inline code (markdown)",
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline"
      ],
      "settings": { "foreground": "#D7A65F" }
    },
    {
      "name": "Link text (markdown)",
      "scope": [
        "string.other.link",
        "string.other.link.title.markdown",
        "markup.link"
      ],
      "settings": {
        "foreground": "#A485DD",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Link URL (markdown)",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#7199EE",
        "fontStyle": "underline"
      }
    },
    {
      "name": "List markers (markdown)",
      "scope": [
        "punctuation.definition.list",
        "punctuation.definition.list.begin",
        "markup.list"
      ],
      "settings": { "foreground": "#A485DD" }
    },
    {
      "name": "Invalid / error tokens",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": { "foreground": "#EE6D85" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#EE6D85",
    "type": "#7199EE",
    "class": "#7199EE",
    "enum": "#7199EE",
    "interface": "#7199EE",
    "struct": "#7199EE",
    "typeParameter": "#7199EE",
    "parameter": "#F6955B",
    "variable": "#A0A8CD",
    "property": "#F6955B",
    "enumMember": "#F6955B",
    "event": "#F6955B",
    "function": "#95C561",
    "method": "#95C561",
    "macro": "#A485DD",
    "keyword": "#EE6D85",
    "comment": "#4A5057",
    "string": "#D7A65F",
    "number": "#A485DD",
    "regexp": "#D7A65F",
    "operator": "#EE6D85",
    "decorator": "#A485DD"
  }
}
